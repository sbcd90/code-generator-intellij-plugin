<idea-plugin>
    <id>com.codegen</id>
    <name>Codegen Ollama Plugin</name>
    <vendor>sbcd90</vendor>

    <description>Simple Codegen Ollama Plugin</description>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.codegen.settings.AppSettings"/>
        <applicationConfigurable id="codegen.settings" displayName="Codegen" parentId="tools"
                                 instance="com.codegen.settings.CodegenConfigurable"/>
    </extensions>

    <actions>
        <action id="GenerateCode"
                class="com.codegen.CursorAction"
                text="Generate Code"
                description="Generate Code From Qwen-3 Model">
            <keyboard-shortcut
                keymap="$default"
                first-keystroke="TAB"/>
        </action>
    </actions>
</idea-plugin>